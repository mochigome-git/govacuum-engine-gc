############
# Database — Supabase, via the REST API (PostgREST), not a direct
# Postgres connection. No connection pool, no DB password needed.
############
# service_role key specifically — NOT anon. This engine needs to bypass
# RLS for both the historical read and the insert. Find it in the
# Supabase dashboard: Project Settings → API → Project API keys.
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="secret key"

# analytics.metrics lives outside the default "public" schema. Two things
# both need to be true or every request 404s/400s:
#   1. This must say "analytics" (matches the schema in your table DDL)
#   2. "analytics" must be added to Supabase's exposed-schemas list:
#      Project Settings → API → Exposed schemas
SUPABASE_SCHEMA=analytics

# How many historical rows (per device_id) to pull for the IQR calculation.
IQR_HISTORY_LIMIT=1000

############
# EMQX — must be the SAME broker gopub-edge's EMQX_* vars point to. This
# engine SUBSCRIBES here (requests come in over EMQX).
############
EMQX_HOST=emqx-host.com
EMQX_PORT=8883
EMQX_USERNAME="secret key"
EMQX_PASSWORD="secret key"
EMQX_TLS_ON=true
EMQX_CA_CERTIFICATE=""
EMQX_CLIENT_ID_PREFIX=vacuum-engine_

# MUST match gopub-edge's MQTT_INSERT_REQUEST_TOPIC exactly — this engine
# subscribes to the same shared request topic and filters for vacuum
# payloads itself (readings.vacuum_start present). Other consumers (e.g.
# gokafka-raw) can subscribe to the same topic independently — MQTT
# delivers each subscriber its own copy.
MQTT_INSERT_REQUEST_TOPIC=gim/devices/payload

############
# Mosquitto (local edge broker) — this engine PUBLISHES replies here, not
# to EMQX. Must match the same Mosquitto instance gopub-edge's MQTT_HOST /
# MQTT_PORT / MQTTS_ON point to, since gopub-edge listens for replies there.
############
MOSQUITTO_HOST=127.0.0.1
MOSQUITTO_PORT=1883
MOSQUITTO_TLS_ON=false
MOSQUITTO_CA_CERTIFICATE=""
MOSQUITTO_CLIENT_ID_PREFIX=vacuum-engine-reply_
